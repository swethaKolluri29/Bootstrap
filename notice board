<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/css/bootstrap.min.css">
    <link href="https://maxcdn.bootstrapcdn.com/font-awesome/4.7.0/css/font-awesome.min.css" rel="stylesheet">

    <title>My Notice Board</title>
    <style>
        .notice {
            display: inline-flex;
            margin-left: 10px;
            margin-top: 10px;
        }
        .notice div {
            width: 240px;
            height: 300px;
            padding-left: 10px;
            padding-top: 5px;
        }
    </style>
</head>
<body>
    <div class="container">
    <div class="d-flex" >
        <div id="notice-1" class="notice">
            <div class="bg-success text-white">
                <h4 class="text-white">Completed Tasks</h4>
                <p>Till Today</p>
                <ul class="list-unstyled">
                    <li><b>Task-1</b></li>
                    <li>-description</li>
                    <li><b>Task-2</b></li>
                    <li>-description</li>
                </ul>
            </div>
        </div>
        
        <div id="notice-2" class="notice" >
             <div class="bg-info text-white">
                <h4 class="text-white">On Going Tasks</h4>
                <p>Important</p>
                <ul class="list-unstyled">
                    <li><b>Task-1</b></li>
                    <li>-description</li>
                    <li><b>Task-2</b></li>
                    <li>-description</li>
                </ul>
            </div>
        </div>
        
        <div id="notice-3" class="notice" >
            <div class="bg-warning text-white">
                <h4 class="text-white">Upcoming Tasks</h4>
                <p>To Do List</p>
                <ul class="list-unstyled">
                    <li><b>Task-1</b></li>
                    <li>-description</li>
                    <li><b>Task-2</b></li>
                    <li>-description</li>
                </ul>
            </div>
        </div>
        
        <div id="notice-4" class="notice" >
            <div class="bg-danger text-white">
                <h4 class="text-white">Pending Tasks</h4>
                <p>Need Help</p>
                <ul class="list-unstyled">
                    <li><b>Task-1</b></li>
                    <li>-description</li>
                    <li><b>Task-2</b></li>
                    <li>-description</li>
                </ul>
            </div>
        </div>
        
         <div id="notice-5" class="notice" >
             <div class="bg-info text-white">
                <h4 class="text-white text-center">Add New</h4>
                <h1 class="text-center">+</h1>
            </div>
        </div>
    </div>
</div>    

<script src="https://cdn.jsdelivr.net/npm/jquery@3.6.0/dist/jquery.slim.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.1/dist/js/bootstrap.bundle.min.js"></script>

</body>
</html>
